<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/game_court_bg"
    android:padding="12dp">

    <!-- Panel de Score (Izquierda) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/panelScore"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#E6121212"
        app:cardCornerRadius="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCORE: 00"
                android:textColor="#FFEB3B"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡APUNTA!"
                android:textColor="#00E676"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Área de Juego (Centro/Derecha) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/gameArea"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginStart="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/panelScore"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgHoop"
            android:layout_width="70dp"
            android:layout_height="110dp"
            android:src="@drawable/game_hoop"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="20dp" />

        <ImageView
            android:id="@+id/imgPlayer"
            android:layout_width="60dp"
            android:layout_height="90dp"
            android:src="@drawable/game_player"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="10dp" />

        <ovh.gabrielhuav.sensores_escom_v2.presentation.game.basketball.TrajectoryView
            android:id="@+id/trajectoryView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ImageView
            android:id="@+id/imgBall"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/game_ball"
            app:layout_constraintBottom_toBottomOf="@id/imgPlayer"
            app:layout_constraintStart_toStartOf="@id/imgPlayer"
            android:layout_marginBottom="55dp"
            android:layout_marginStart="32dp"
            android:elevation="6dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Controles (Abajo del score) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/controlsPanel"
        android:layout_width="160dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="#E6121212"
        app:cardCornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="@id/gameArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/panelScore">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp"
            android:gravity="center">

            <ProgressBar
                android:id="@+id/progressAngle"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="50"
                android:progressTint="#00E5FF"
                android:layout_marginBottom="8dp"/>

            <ProgressBar
                android:id="@+id/progressPower"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#FF3D00" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botones de Acción (Abajo) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/gameArea"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAction"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="INICIAR"
            android:textSize="14sp"
            app:backgroundTint="#00C853"
            app:cornerRadius="8dp"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExit"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:text="SALIR"
            android:textSize="14sp"
            app:backgroundTint="#D50000"
            app:cornerRadius="8dp"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
